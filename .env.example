# ── Gemini (AI 호출 2곳: 사진 분석 / 요청문 생성) ──
# 발급: https://aistudio.google.com/apikey
# 주의: Vercel 환경변수에도 GEMINI_API_KEY 로 등록. VITE_ 접두사 금지(빌드에 박힘).
GEMINI_API_KEY=

# 사용할 모델 (무료 티어 Flash 계열)
# 참고: 일부 계정은 gemini-2.0-flash 무료 한도가 0입니다. 그때는 gemini-flash-latest 사용.
GEMINI_MODEL=gemini-flash-latest

# 로컬 서버 포트
PORT=3000
